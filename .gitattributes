# Normalize line endings for all text files
* text=auto

# Force LF for source code
*.rs text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.game text eol=lf
*.sh text eol=lf

# Binary files
*.wasm binary
*.png binary
*.jpg binary
*.ico binary
