// Scan Ring — 20px analysis indicator for ActionBar.
// Rotating arc with memory trail — a radar sweep that shows where it's been.

cinematic "scan-ring" {
  // Fading trail of the sweep
  layer sweep memory: 0.90 {
    rotate(3.0) | ring(0.28, 0.06) | mask_arc(2.0) | glow(2.8) | tint(0.83, 0.55, 0.12)
  }

  // Dim track ring
  layer track {
    ring(0.28, 0.008) | glow(0.5) | tint(0.2, 0.2, 0.2)
  }

  pass edge {
    vignette(0.3)
  }
}
