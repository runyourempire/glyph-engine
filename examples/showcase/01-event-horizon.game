// Event Horizon — GPU vortex fluid simulation.
// Based on the proven working vortex example, with blue color matrix.

cinematic "event-horizon" {
  layer bg {
    circle(0.5) | glow(1.5) | tint(0.01, 0.005, 0.025)
  }

  flow {
    type: vortex
    scale: 2.0
    speed: 0.3
    octaves: 3
    strength: 1.5
  }

  matrix color {
    [
      0.15, 0.05, 0.0,
      0.05, 0.15, 0.1,
      0.5, 0.3, 0.9
    ]
  }

  pass frame { vignette(0.3) }
}
