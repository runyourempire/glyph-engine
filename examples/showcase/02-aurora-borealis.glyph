// Aurora Borealis — northern lights shimmer across polar sky.
// Flowing curtains of green, blue, violet. Only palette(). No blend:add.
// No voronoi starfield — the curtain layers ARE the scene.

cinematic "aurora-borealis" {
  layer config {
    activity: 0.5
    curtain: 0.0
  }

  // Green curtain — oxygen emission at 100-300km altitude
  layer green memory: 0.91 {
    translate(0.0, 0.1)
    | warp(scale: 1.5, octaves: 5, persistence: 0.6, strength: 0.3 + activity * 0.12)
    | fbm(scale: 2.0, octaves: 5)
    | palette(
        a_r: 0.001, a_g: 0.005, a_b: 0.002,
        b_r: 0.005, b_g: 0.15, b_b: 0.02,
        c_r: 0.5, c_g: 1.0, c_b: 0.3,
        d_r: 0.0, d_g: 0.33, d_b: 0.1
      )
  }

  // Blue-violet curtain — nitrogen emission below 100km
  layer violet memory: 0.88 {
    translate(0.06, -0.08)
    | warp(scale: 2.0, octaves: 4, persistence: 0.55, strength: 0.25 + curtain * 0.1)
    | fbm(scale: 2.5, octaves: 5)
    | palette(
        a_r: 0.002, a_g: 0.001, a_b: 0.004,
        b_r: 0.015, b_g: 0.03, b_b: 0.12,
        c_r: 0.3, c_g: 0.5, c_b: 1.0,
        d_r: 0.15, d_g: 0.25, d_b: 0.5
      )
  }

  // Curtain apex — bright concentrated peak
  layer peak memory: 0.84 {
    translate(0.0, 0.2)
    | warp(scale: 2.5, octaves: 4, strength: 0.2 + activity * 0.08)
    | simplex(3.0)
    | palette(
        a_r: 0.002, a_g: 0.008, a_b: 0.002,
        b_r: 0.015, b_g: 0.18, b_b: 0.02,
        c_r: 0.8, c_g: 1.0, c_b: 0.6,
        d_r: 0.0, d_g: 0.33, d_b: 0.0
      )
  }

  // Horizon glow — faint reflection on snowline
  layer horizon memory: 0.80 {
    translate(0.0, -0.35)
    | fbm(scale: 1.5, octaves: 3)
    | palette(
        a_r: 0.003, a_g: 0.004, a_b: 0.006,
        b_r: 0.004, b_g: 0.006, b_b: 0.01,
        c_r: 0.5, c_g: 0.5, c_b: 0.5,
        d_r: 0.0, d_g: 0.0, d_b: 0.0
      )
  }

  arc {
    curtain: 0.0 -> 1.0 over 20s ease-in-out
    activity: 0.5 -> 0.9 over 15s ease-in-out
  }

  resonate {
    activity -> green.brightness * 0.3
    curtain -> violet.intensity * 0.2
    curtain -> peak.brightness * 0.4
  }

  pass frame { vignette(0.45) }
}
