// OCEAN COAST — Hand-crafted living wallpaper
// Rhythmic wave approach, foam dissolution, spray mist, deep water shimmer,
// salt-air haze, and the endless breathing of the tide.
// This is not a wallpaper. This is a window onto the shore.

cinematic "living-ocean-coast" {
  texture "photo" from "ocean-coast.jpg"
  texture "depth" from "ocean-coast-depth.png"
  texture "flow" from "ocean-coast-flow.png"
  texture "mask_water" from "ocean-coast-mask_water.png"
  texture "mask_sky" from "ocean-coast-mask_sky.png"

  // ══════ THE SHORE — solid earth, gentle parallax ══════
  layer world {
    parallax("photo", depth: "depth", strength: 0.020, orbit_speed: 0.06)
  }

  // ══════ WAVE APPROACH — directional flow of actual ocean pixels ══════
  layer wave_flow opacity: 0.92 {
    flowmap("photo", "flow", speed: 0.18, scale: 0.06)
    | mask("mask_water")
  }

  // ══════ SKY DRIFT — slow cloud movement ══════
  layer sky_drift opacity: 0.85 {
    distort(scale: 0.25, speed: 0.04, strength: 0.012)
    | sample("photo")
    | mask("mask_sky")
  }

  // ══════ FOAM CRESTS — white foam appearing at wave peaks ══════
  layer foam opacity: 0.18 blend: add {
    translate(time * 0.015, time * 0.035)
    | warp(scale: 1.8, octaves: 4, persistence: 0.55, strength: 0.30)
    | voronoi(6.0)
    | glow(3.0)
    | tint(0.95, 0.97, 1.0)
    | mask("mask_water")
  }

  // ══════ FOAM DISSOLVE — secondary foam layer, slower, softer ══════
  layer foam_dissolve opacity: 0.12 blend: screen {
    translate(time * 0.008, time * 0.02)
    | warp(scale: 0.9, octaves: 3, persistence: 0.50, strength: 0.18)
    | voronoi(4.0)
    | glow(4.5)
    | tint(0.88, 0.92, 1.0)
    | mask("mask_water")
  }

  // ══���═══ DEEP WATER SHIMMER — caustic light in deeper areas ═��════
  layer deep_shimmer opacity: 0.10 blend: screen {
    translate(time * 0.025, time * 0.012)
    | warp(scale: 3.5, octaves: 3, strength: 0.20)
    | voronoi(14.0)
    | glow(2.0)
    | tint(0.3, 0.65, 0.85)
    | mask("mask_water")
  }

  // ══════ SPRAY MIST — fine mist rising from where waves meet shore ══���═══
  layer spray opacity: 0.08 blend: screen {
    translate(time * 0.006, sin(time * 0.15) * 0.008)
    | warp(scale: 1.2, octaves: 5, persistence: 0.60, strength: 0.25)
    | fbm(scale: 1.8, octaves: 5, persistence: 0.50)
    | glow(1.0)
    | tint(0.90, 0.93, 1.0)
    | mask("depth")
  }

  // ══════ SALT AIR — coastal atmospheric haze ══════
  layer salt_air opacity: 0.07 blend: screen {
    translate(time * 0.010, sin(time * 0.06) * 0.004)
    | warp(scale: 0.6, octaves: 4, persistence: 0.55, strength: 0.14)
    | fbm(scale: 0.8, octaves: 4, persistence: 0.50)
    | glow(1.2)
    | tint(0.75, 0.82, 0.95)
    | mask("depth", invert: 1)
  }

  // ═���════ TIDE BREATH — whole-scene intensity modulation ══════
  layer tide_pulse opacity: 0.06 blend: screen {
    translate(sin(time * 0.08) * 0.003, time * 0.002)
    | warp(scale: 0.3, octaves: 2, persistence: 0.5, strength: 0.06)
    | fbm(scale: 0.25, octaves: 3, persistence: 0.5)
    | glow(1.5)
    | tint(0.6, 0.78, 0.95)
  }

  // ══════ HORIZON GLOW — light at the horizon line ══════
  layer horizon opacity: 0.09 blend: screen {
    translate(time * 0.003, time * 0.001)
    | warp(scale: 0.2, octaves: 2, persistence: 0.5, strength: 0.04)
    | fbm(scale: 0.15, octaves: 2, persistence: 0.5)
    | glow(2.0)
    | tint(0.85, 0.80, 0.72)
    | mask("mask_sky")
  }

  // ══════ CINEMATIC POST ══════
  pass soften { blur(0.6) }
  pass frame { vignette(0.25) }
  pass film { film_grain(0.016) }
}
