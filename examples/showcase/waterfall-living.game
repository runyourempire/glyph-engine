// WATERFALL — Hand-crafted living wallpaper
// Powerful vertical cascade, turbulent splash pool, rising mist,
// wet rock shimmer, and rainbow light diffraction in the spray.
// This is not a wallpaper. This is a window into the gorge.

cinematic "living-waterfall" {
  texture "photo" from "waterfall.jpg"
  texture "depth" from "waterfall-depth.png"
  texture "flow" from "waterfall-flow.png"
  texture "mask_water" from "waterfall-mask_water.png"
  texture "mask_sky" from "waterfall-mask_sky.png"

  // ══════ THE GORGE — rock face, barely breathes ═��════
  layer world {
    parallax("photo", depth: "depth", strength: 0.015, orbit_speed: 0.05)
  }

  // ══════ CASCADE — actual water pixels flowing downward ══════
  layer cascade opacity: 0.94 {
    flowmap("photo", "flow", speed: 0.35, scale: 0.10)
    | mask("mask_water")
  }

  // ══════ FALL TURBULENCE — chaotic white water at the cascade ══════
  layer turbulence opacity: 0.22 blend: add {
    translate(time * 0.008, time * 0.065)
    | distort(scale: 3.5, speed: 3.0, strength: 0.08)
    | warp(scale: 2.0, octaves: 4, persistence: 0.60, strength: 0.35)
    | voronoi(7.0)
    | glow(2.5)
    | tint(0.92, 0.95, 1.0)
    | mask("mask_water")
  }

  // ══════ SPLASH ZONE — impact point where water hits pool ══════
  layer splash opacity: 0.16 blend: add {
    translate(time * 0.012, time * 0.005)
    | distort(scale: 5.0, speed: 4.0, strength: 0.12)
    | voronoi(10.0)
    | glow(3.5)
    | tint(0.88, 0.92, 1.0)
    | mask("mask_water")
  }

  // ══════ POOL RIPPLES — concentric waves in the catch pool ══════
  layer pool_ripple opacity: 0.10 blend: screen {
    translate(time * 0.006, time * 0.003)
    | warp(scale: 4.0, octaves: 3, strength: 0.15)
    | voronoi(16.0)
    | glow(2.0)
    | tint(0.4, 0.65, 0.85)
    | mask("mask_water")
  }

  // ══════ RISING MIST — spray cloud ascending from impact ══════
  layer mist_rise opacity: 0.14 blend: screen {
    translate(sin(time * 0.08) * 0.005, time * -0.018)
    | warp(scale: 0.7, octaves: 5, persistence: 0.65, strength: 0.28)
    | fbm(scale: 1.0, octaves: 5, persistence: 0.55)
    | glow(1.0)
    | tint(0.88, 0.90, 0.98)
    | mask("depth")
  }

  // ══════ MIST VEIL — diffuse mist layer across the scene ══════
  layer mist_veil opacity: 0.08 blend: screen {
    translate(time * 0.004, sin(time * 0.05) * 0.003)
    | warp(scale: 0.5, octaves: 4, persistence: 0.55, strength: 0.16)
    | fbm(scale: 0.6, octaves: 4, persistence: 0.50)
    | glow(1.5)
    | tint(0.82, 0.86, 0.95)
    | mask("depth", invert: 1)
  }

  // ══════ RAINBOW REFRACTION — prismatic light in the spray ══════
  layer rainbow opacity: 0.05 blend: add {
    translate(time * 0.002, time * 0.001)
    | warp(scale: 0.4, octaves: 3, persistence: 0.5, strength: 0.10)
    | fbm(scale: 0.35, octaves: 3, persistence: 0.55)
    | glow(3.0)
    | tint(0.85, 0.55, 0.95)
    | mask("depth")
  }

  // ══════ WET ROCK SHIMMER — glistening moisture on stone ══════
  layer wet_rock opacity: 0.06 blend: screen {
    translate(time * 0.003, time * 0.008)
    | distort(scale: 12.0, speed: 1.5, strength: 0.04)
    | voronoi(22.0)
    | glow(6.0)
    | tint(0.70, 0.75, 0.85)
    | mask("depth")
  }

  // ══════ SKY DRIFT ══════
  layer sky opacity: 0.82 {
    distort(scale: 0.20, speed: 0.03, strength: 0.010)
    | sample("photo")
    | mask("mask_sky")
  }

  // ══════ CINEMATIC POST ══════
  pass soften { blur(0.5) }
  pass frame { vignette(0.30) }
  pass film { film_grain(0.012) }
}
