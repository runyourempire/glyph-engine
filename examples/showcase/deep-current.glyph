// Deep Current — ocean currents flowing across your screen.
// FORMULA: living-field architecture (bright palette base + tiled organisms + NO blend:add).
// Mouse-reactive. Click to intensify. LLM-customizable via config.

cinematic "deep-current" {
  layer config {
    flow_speed: 0.3
    bio_glow: 0.0
  }

  // PRIMARY VISUAL: flowing water texture — bright palette, strong warp
  layer water memory: 0.92 {
    warp(scale: 1.2, octaves: 6, persistence: 0.55, strength: 0.32 + mouse_down * 0.08)
    | distort(scale: 2.0, speed: flow_speed, strength: 0.12)
    | fbm(scale: 2.0, octaves: 5, persistence: 0.5)
    | palette(
        a_r: 0.25, a_g: 0.35, a_b: 0.5,
        b_r: 0.2, b_g: 0.25, b_b: 0.3,
        c_r: 0.8, c_g: 0.6, c_b: 0.4,
        d_r: 0.55, d_g: 0.6, d_b: 0.7
      )
  }

  // SECONDARY TEXTURE: finer current detail on top
  layer ripples memory: 0.86 {
    warp(scale: 2.5 + mouse_x * 0.4, octaves: 5, persistence: 0.5, strength: 0.28 + mouse_down * 0.06)
    | distort(scale: 3.0, speed: flow_speed * 1.3, strength: 0.1)
    | fbm(scale: 4.0, octaves: 4, persistence: 0.45)
    | palette(
        a_r: 0.2, a_g: 0.3, a_b: 0.45,
        b_r: 0.18, b_g: 0.22, b_b: 0.28,
        c_r: 1.0, c_g: 0.8, c_b: 0.5,
        d_r: 0.6, d_g: 0.65, d_b: 0.72
      )
  }

  // ORGANISMS: tiled bioluminescent dots flowing through water (NO blend:add)
  layer organisms memory: 0.84 {
    distort(scale: 4.0, speed: flow_speed * 0.7, strength: 0.18)
    | warp(scale: 2.0, octaves: 3, strength: 0.22)
    | repeat(0.13, 0.13)
    | circle(0.018)
    | glow(2.5 + bio_glow * 1.0)
    | tint(0.15, 0.5, 0.85)
  }

  // TRAILS: high memory creates flowing vapor (NO blend:add)
  layer vapor memory: 0.95 {
    distort(scale: 3.0, speed: flow_speed * 0.5, strength: 0.12)
    | warp(scale: 2.0, octaves: 4, persistence: 0.5, strength: 0.22)
    | simplex(5.0)
    | glow(1.2 + bio_glow * 0.4)
    | tint(0.1, 0.35, 0.65)
  }

  // SPARKLES: rare bright flashes (NO blend:add)
  layer sparkles memory: 0.70 {
    distort(scale: 6.0, speed: flow_speed * 0.9, strength: 0.22)
    | warp(scale: 3.0, octaves: 3, strength: 0.3)
    | fbm(scale: 16.0, octaves: 2)
    | glow(3.5 + bio_glow * 1.0)
    | tint(0.4, 0.7, 1.0)
  }

  // AMBIENT: warm radial base (NO blend:add)
  layer ambient {
    radial_fade(0.0, 0.65)
    | palette(
        a_r: 0.22, a_g: 0.28, a_b: 0.4,
        b_r: 0.15, b_g: 0.18, b_b: 0.25,
        c_r: 0.6, c_g: 0.5, c_b: 0.35,
        d_r: 0.0, d_g: 0.08, d_b: 0.12
      )
  }

  arc {
    bio_glow: 0.0 -> 0.8 over 10s ease-in-out
  }

  resonate {
    bio_glow -> organisms.brightness * 0.3
    bio_glow -> sparkles.brightness * 0.25
  }

  pass glow { blur(1.5) }
  pass frame { vignette(0.25) }
}
