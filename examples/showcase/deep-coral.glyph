// Deep Coral — reef formation at abyssal pressure.
// The proven coral reaction-diffusion pattern recolored to ocean blue.
// Bioluminescent organisms building calcium carbonate.

cinematic "deep-coral" {
  layer bg {
    circle(0.5) | glow(0.6) | tint(0.003, 0.008, 0.02)
  }

  layer config {
    color_r: 0.3
    color_g: 0.6
    color_b: 1.5
  }

  react {
    feed: 0.037
    kill: 0.06
    diffuse_a: 1.0
    diffuse_b: 0.5
    seed: center(0.2)
  }

  pass frame { vignette(0.35) }
}
