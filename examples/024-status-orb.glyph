// Status Orb — 10px micro living indicator for Ollama connection status.
// Even at 10px: domain warp gives it organic life vs a dead pixel.

cinematic "status-orb" {
  layer config {
    intensity: 1.0
    green: 0.0
  }

  // Living core — warped circle with memory glow
  layer orb memory: 0.85 {
    if green > 0.5 {
      warp(scale: 3.0, octaves: 2, strength: 0.08)
      | circle(0.22) | glow(3.0) | tint(0.15, 0.85, 0.3)
    } else {
      warp(scale: 3.0, octaves: 2, strength: 0.08)
      | circle(0.22) | glow(3.0) | tint(0.83, 0.5, 0.1)
    }
  }

  // Soft edge
  pass soft {
    vignette(0.3)
  }
}
