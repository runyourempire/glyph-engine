// Engagement Bars — activity level indicator.
// Warped noise field with memory trails, organic green texture.

cinematic "engagement-bars" {
  layer config {
    glow_val: 1.2
  }

  // Organic noise field with persistence
  layer field memory: 0.88 {
    warp(scale: 2.0, octaves: 2, strength: 0.1)
    | simplex(4.0) | glow(glow_val) | tint(0.08, 0.45, 0.1)
  }

  pass edge {
    vignette(0.3)
  }
}
