// Radar Sweep — radar sweep with detection blips
cinematic "radar-sweep" {
  layer sweep memory: 0.90 {
    rotate(speed: 3.0)
    | ring(0.32, 0.06)
    | mask_arc(2.0)
    | glow(2.5)
    | tint(0.1, 0.8, 0.3)
  }

  layer rings {
    ring(0.32, 0.006) | glow(0.5) | tint(0.1, 0.4, 0.15)
  }

  layer inner_ring {
    ring(0.18, 0.004) | glow(0.4) | tint(0.08, 0.3, 0.12)
  }

  layer center {
    circle(0.02) | glow(2.0) | tint(0.1, 0.8, 0.3)
  }

  pass frame { vignette(0.6) }
}
