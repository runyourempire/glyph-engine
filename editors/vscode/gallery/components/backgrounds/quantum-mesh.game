// Quantum Mesh — interconnected lattice grid
cinematic "quantum-mesh" {
  layer mesh memory: 0.93 {
    warp(scale: 2.0, octaves: 5, persistence: 0.6, strength: 0.2)
    | distort(scale: 1.5, speed: 0.15, strength: 0.1)
    | voronoi(scale: 7.0)
    | palette(electric)
  }

  layer nodes memory: 0.85 {
    warp(scale: 4.0, octaves: 2, strength: 0.1)
    | voronoi(scale: 15.0)
    | glow(0.8)
    | tint(0.2, 0.6, 0.9)
  }

  pass edge { vignette(0.5) }
}
