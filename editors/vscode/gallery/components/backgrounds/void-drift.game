// Void Drift — dark void with subtle simplex movement
cinematic "void-drift" {
  layer drift memory: 0.97 {
    warp(scale: 1.5, octaves: 3, strength: 0.08)
    | simplex(scale: 2.0)
    | glow(0.3)
    | tint(0.08, 0.06, 0.12)
  }

  layer motes memory: 0.90 {
    distort(scale: 1.0, speed: 0.1, strength: 0.05)
    | voronoi(scale: 20.0)
    | glow(0.4)
    | tint(0.15, 0.12, 0.2)
  }

  pass edge { vignette(0.4) }
}
