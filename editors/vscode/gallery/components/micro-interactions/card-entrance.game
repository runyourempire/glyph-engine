// Card Entrance — card reveal entrance animation
cinematic "card-entrance" {
  layer config {
    reveal: 0.0
  }

  layer glow_edge {
    box(0.35, 0.22) | shell(width: 0.008) | glow(2.0) | tint(1.0, 1.0, 1.0)
  }

  layer fill {
    radial_fade(inner: 0.0, outer: 0.5) | glow(0.6) | tint(0.9, 0.9, 1.0)
  }

  arc {
    reveal: 0.0 -> 1.0 over 2s ease-out
  }

  resonate {
    reveal -> glow_edge.brightness * 0.8
  }

  pass frame { vignette(0.3) }
}
