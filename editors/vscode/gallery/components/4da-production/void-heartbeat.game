// Void Heartbeat — 4DA void engine heartbeat indicator
cinematic "void-heartbeat" {
  layer config {
    alive: 1.0
  }

  layer core memory: 0.92 {
    warp(scale: 3.0, octaves: 2, strength: 0.06)
    | circle(0.15) | glow(2.5) | tint(1.0, 1.0, 1.0)
  }

  layer halo {
    ring(0.25, 0.008) | glow(1.0) | tint(0.5, 0.5, 0.55)
  }

  resonate {
    alive -> core.brightness * 0.5
  }

  pass edge { vignette(0.3) }
}
