// Shimmer Wave — gentle shimmering wave pattern
cinematic "shimmer-wave" {
  layer wave {
    warp(scale: 1.5, octaves: 3, strength: 0.1)
    | distort(scale: 3.0, speed: 0.4, strength: 0.15)
    | simplex(scale: 4.0)
    | glow(1.5)
    | tint(0.8, 0.85, 1.0)
  }

  layer highlights memory: 0.92 {
    warp(scale: 2.0, octaves: 2, strength: 0.08)
    | fbm(scale: 5.0, octaves: 3, persistence: 0.4)
    | glow(0.6)
    | tint(0.9, 0.92, 1.0)
  }
}
