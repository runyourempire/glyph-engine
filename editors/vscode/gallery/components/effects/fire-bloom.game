// Fire Bloom — blooming fire effect with ember glow
cinematic "fire-bloom" {
  layer flame memory: 0.88 {
    warp(scale: 2.5, octaves: 5, persistence: 0.6, strength: 0.35)
    | distort(scale: 2.0, speed: 1.0, strength: 0.2)
    | fbm(scale: 3.0, octaves: 4, persistence: 0.5)
    | palette(fire)
  }

  layer core {
    circle(0.1) | glow(4.0) | tint(1.0, 0.9, 0.5)
  }

  pass bloom { blur(2.0) }
  pass frame { vignette(0.5) }
}
