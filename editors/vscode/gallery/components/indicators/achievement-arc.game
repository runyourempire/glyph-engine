// Achievement Arc — golden completion ring
cinematic "achievement-arc" {
  layer config {
    fill_angle: 5.3
    glow_val: 2.0
  }

  layer track {
    ring(0.34, 0.008) | glow(0.5) | tint(0.3, 0.3, 0.3)
  }

  layer fill memory: 0.88 {
    warp(scale: 4.0, octaves: 2, strength: 0.06)
    | ring(0.34, 0.03) | mask_arc(fill_angle) | glow(glow_val) | tint(0.83, 0.69, 0.22)
  }

  layer flash {
    circle(0.1) | glow(1.2) | tint(1.0, 0.9, 0.6)
  }

  pass bloom { blur(1.5) }
}
