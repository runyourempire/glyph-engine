// Status Pulse — ambient status dot with resonance
cinematic "status-pulse" {
  layer config {
    active: 1.0
  }

  layer core memory: 0.85 {
    warp(scale: 3.0, octaves: 2, strength: 0.06)
    | circle(0.18) | glow(4.0) | tint(0.13, 0.77, 0.37)
  }

  layer outer {
    ring(0.28, 0.006) | glow(1.0) | tint(0.1, 0.4, 0.2)
  }

  resonate {
    active -> core.brightness * 0.5
  }

  pass edge { vignette(0.3) }
}
