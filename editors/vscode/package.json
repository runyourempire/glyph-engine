{
  "name": "game-language",
  "displayName": "GAME Language",
  "description": "Syntax highlighting and language server for GAME DSL (.game files) — Generative Animation Matrix Engine",
  "version": "0.5.0",
  "publisher": "4da-systems",
  "license": "FSL-1.1-Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/runyourempire/game-engine"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "game",
    "shader",
    "wgsl",
    "glsl",
    "dsl",
    "animation",
    "generative",
    "4da"
  ],
  "activationEvents": [
    "onLanguage:game"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "game",
        "aliases": [
          "GAME",
          "game"
        ],
        "extensions": [
          ".game"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "game",
        "scopeName": "source.game",
        "path": "./syntaxes/game.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "game",
        "path": "./snippets/game.json"
      }
    ],
    "commands": [
      {
        "command": "game.openPreview",
        "title": "GAME: Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "game.export",
        "title": "GAME: Export Component",
        "icon": "$(export)"
      },
      {
        "command": "game.exportCopyJs",
        "title": "GAME: Copy JS to Clipboard"
      },
      {
        "command": "game.exportCopyHtml",
        "title": "GAME: Copy HTML Embed"
      },
      {
        "command": "game.exportCopyReact",
        "title": "GAME: Copy React Usage"
      },
      {
        "command": "game.exportSaveJs",
        "title": "GAME: Save JS File"
      },
      {
        "command": "game.exportSaveHtml",
        "title": "GAME: Save Standalone HTML"
      },
      {
        "command": "game.openGallery",
        "title": "GAME: Open Component Gallery",
        "icon": "$(library)"
      },
      {
        "command": "game.openAi",
        "title": "GAME: Generate with AI",
        "icon": "$(sparkle)"
      }
    ],
    "keybindings": [
      {
        "command": "game.openPreview",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "editorLangId == game"
      },
      {
        "command": "game.openGallery",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorLangId == game"
      },
      {
        "command": "game.openAi",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorLangId == game"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "game.openPreview",
          "when": "editorLangId == game",
          "group": "navigation"
        },
        {
          "command": "game.export",
          "when": "editorLangId == game",
          "group": "navigation"
        },
        {
          "command": "game.openAi",
          "when": "editorLangId == game",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "GAME Language",
      "properties": {
        "game.serverPath": {
          "type": "string",
          "default": "game",
          "description": "Path to the game compiler binary. If not absolute, searches PATH."
        },
        "game.trace.server": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "description": "Traces the communication between VS Code and the GAME language server."
        },
        "game.ai.apiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for AI component generation."
        },
        "game.ai.model": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "description": "Claude model to use for AI generation."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "echo skipped",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
