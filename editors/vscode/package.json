{
  "name": "glyph-language",
  "displayName": "GAME Language",
  "description": "Syntax highlighting and language server for GAME DSL (.glyph files) — Generative Animation Matrix Engine",
  "version": "0.5.0",
  "publisher": "4da-systems",
  "license": "FSL-1.1-Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/runyourempire/glyph-engine"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "glyph",
    "shader",
    "wgsl",
    "glsl",
    "dsl",
    "animation",
    "generative",
    "4da"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "glyph",
        "aliases": [
          "GAME",
          "glyph"
        ],
        "extensions": [
          ".glyph"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "glyph",
        "scopeName": "source.glyph",
        "path": "./syntaxes/glyph.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "glyph",
        "path": "./snippets/glyph.json"
      }
    ],
    "commands": [
      {
        "command": "glyph.openPreview",
        "title": "GAME: Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "glyph.export",
        "title": "GAME: Export Component",
        "icon": "$(export)"
      },
      {
        "command": "glyph.exportCopyJs",
        "title": "GAME: Copy JS to Clipboard"
      },
      {
        "command": "glyph.exportCopyHtml",
        "title": "GAME: Copy HTML Embed"
      },
      {
        "command": "glyph.exportCopyReact",
        "title": "GAME: Copy React Usage"
      },
      {
        "command": "glyph.exportSaveJs",
        "title": "GAME: Save JS File"
      },
      {
        "command": "glyph.exportSaveHtml",
        "title": "GAME: Save Standalone HTML"
      },
      {
        "command": "glyph.openGallery",
        "title": "GAME: Open Component Gallery",
        "icon": "$(library)"
      },
      {
        "command": "glyph.openAi",
        "title": "GAME: Generate with AI",
        "icon": "$(sparkle)"
      }
    ],
    "keybindings": [
      {
        "command": "glyph.openPreview",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "editorLangId == glyph"
      },
      {
        "command": "glyph.openGallery",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorLangId == glyph"
      },
      {
        "command": "glyph.openAi",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorLangId == glyph"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "glyph.openPreview",
          "when": "editorLangId == glyph",
          "group": "navigation"
        },
        {
          "command": "glyph.export",
          "when": "editorLangId == glyph",
          "group": "navigation"
        },
        {
          "command": "glyph.openAi",
          "when": "editorLangId == glyph",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "GAME Language",
      "properties": {
        "glyph.serverPath": {
          "type": "string",
          "default": "glyph",
          "description": "Path to the glyph compiler binary. If not absolute, searches PATH."
        },
        "glyph.trace.server": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "description": "Traces the communication between VS Code and the GAME language server."
        },
        "glyph.ai.apiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for AI component generation."
        },
        "glyph.ai.model": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "description": "Claude model to use for AI generation."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test:e2e": "wdio run wdio.conf.ts",
    "test:e2e:ci": "xvfb-run -a wdio run wdio.conf.ts"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "typescript": "^5.3.0",
    "wdio-vscode-service": "^6.1.4"
  }
}
